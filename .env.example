# ------------------------------------------------------------------
# GymHere environment. Copy to .env.local and fill with DEMO/test keys.
# Production = swap these values (no code changes). See BUILD-PLAN.md §2.
# ------------------------------------------------------------------

# App mode: demo | production
APP_MODE=demo

# --- Database: Neon Postgres ---
DATABASE_URL=postgres://user:password@ep-xxxx.neon.tech/neondb?sslmode=require

# --- Auth: Clerk (orgs OFF, custom tenancy in DB) ---
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx
CLERK_WEBHOOK_SIGNING_SECRET=whsec_xxx
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# --- Payments: Razorpay (test mode) ---
RAZORPAY_MODE=test
RAZORPAY_KEY_ID=rzp_test_xxx
RAZORPAY_KEY_SECRET=xxx
RAZORPAY_WEBHOOK_SECRET=whsec_test

# --- File storage: UploadThing ---
UPLOADTHING_TOKEN=xxx

# --- Email: Resend ---
RESEND_API_KEY=re_test_xxx
RESEND_FROM_EMAIL=GymHere <noreply@gymhere.app>

# --- Rate limiting: Upstash Redis ---
UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=xxx

# --- App URL (used for webhooks, OG, microsite links) ---
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Demo seed (optional): set to YOUR email to claim a seeded role on signup ---
# DEMO_OWNER_EMAIL=you@example.com   # sign up with this → the populated demo gym
# DEMO_ADMIN_EMAIL=you@example.com   # sign up with this → the super admin panel

